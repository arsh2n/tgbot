# ── Required ───────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:ABCDefgh_your_token_here

# ── Optional (leave blank to fall back to text-only messages) ──────────────────
# Telegram file_id (recommended – fast) or a public HTTPS image URL

# Your proxy packages catalogue image
CATALOGUE_PHOTO=

# Your Paytm / UPI QR code image
QR_CODE_PHOTO=

# ── Channel & support ──────────────────────────────────────────────────────────
DEMO_CHANNEL=https://t.me/your_demo_channel
SUPPORT=@yoursupporthandle

# ── Railway sets PORT automatically; set WEBHOOK_URL after first deploy ────────
# e.g. https://myproxybot.up.railway.app
WEBHOOK_URL=
PORT=8080
